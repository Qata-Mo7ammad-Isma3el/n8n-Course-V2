        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{ $json.targetNumber }}\",\n  \"mediatype\": \"{{ $json.mediatype }}\",\n  \"mimetype\": \"{{ $json.mimetype }}\",\n  \"caption\": \"{{ $json.caption }}\",\n  \"media\": \"{{ $json.media }}\",\n  \"fileName\": \"{{ $json.fileName }}\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [380, 0],
      "id": "http-media-002",
      "name": "Evolution API - Send Media"
    },
    {
      "parameters": {
        "content": "### ⚠️ Common Gotchas\n\n- **`mediatype` and `mimetype` mismatch** → Evolution rejects.\n  - For PDF: `mediatype: document`, `mimetype: application/pdf`\n  - For MP4: `mediatype: video`, `mimetype: video/mp4`\n- **URL behind auth** → Evolution can't fetch. Use base64 instead.\n- **No `fileName`** → documents arrive without a name. Always set it.\n- **Image too large** → some Evolution builds cap at ~5MB. Compress before sending.",
        "height": 320,
        "width": 420,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [620, -260],
      "typeVersion": 1,
      "id": "note-gotchas-002",
      "name": "Gotchas Note"
    }
